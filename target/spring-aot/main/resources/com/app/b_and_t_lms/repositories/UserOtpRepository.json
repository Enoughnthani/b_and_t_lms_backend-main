      "signature": "public abstract void com.app.b_and_t_lms.repositories.UserOtpRepository.deleteAllExpired(java.time.LocalDateTime)",
      "query": {
        "query": "DELETE FROM UserOtp u WHERE u.expiryDate < :now"
      }
    },
    {
      "name": "findByUserId",
      "signature": "public abstract java.util.Optional<com.app.b_and_t_lms.models.UserOtp> com.app.b_and_t_lms.repositories.UserOtpRepository.findByUserId(java.lang.Long)",
      "query": {
        "query": "SELECT u FROM UserOtp u WHERE u.user.id = :id"
      }
    },
    {
