      "signature": "public abstract java.util.Optional<com.app.b_and_t_lms.models.UserOtp> com.app.b_and_t_lms.repositories.UserOtpRepository.findByUserIdAndOtpAndUsedFalseAndExpiryDateAfter(java.lang.Long,java.lang.String,java.time.LocalDateTime)",
